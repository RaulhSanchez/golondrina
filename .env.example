# Stripe
# Clave secreta — Stripe Dashboard > Developers > API keys > Secret key
STRIPE_SECRET_KEY=sk_live_...

# Secreto del webhook — Stripe Dashboard > Developers > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ID del Payment Link de "El Arca de Noé"
# Stripe Dashboard > Payment Links > (tu link) > el ID es "plink_XXXXXX"
# (distinto de la URL buy.stripe.com/...)
PAYMENT_LINK_ARCA_DE_NOE=plink_...

# Gmail SMTP
# Cuenta de Gmail que enviará los emails
GMAIL_USER=hola@golondrinaguerrera.com

# Contraseña de aplicación de Gmail (no la contraseña normal)
# Google Account > Seguridad > Verificación en dos pasos > Contraseñas de aplicación
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

